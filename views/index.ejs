<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Music Bot Dashboard</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
</head>
<body>
    <div class="background-radial"></div>
    <div class="container">
        <header>
            <div class="logo">
                <span class="logo-icon">🎵</span>
                <h1>Music<span>Bot</span></h1>
            </div>
            <div class="status-badge" id="bot-status">
                <span class="status-dot"></span>
                <%= stats.status %>
            </div>
        </header>

        <main>
            <section class="stats-grid">
                <div class="stat-card">
                    <div class="stat-icon">🏠</div>
                    <div class="stat-info">
                        <h3><%= stats.guilds %></h3>
                        <p>Servers</p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">👥</div>
                    <div class="stat-info">
                        <h3><%= stats.users %></h3>
                        <p>Total Users</p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">⚡</div>
                    <div class="stat-info">
                        <h3><%= stats.ping %>ms</h3>
                        <p>Latency</p>
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-icon">🕒</div>
                    <div class="stat-info">
                        <h3><%= stats.uptime %></h3>
                        <p>Uptime</p>
                    </div>
                </div>
                <div class="stat-card ping-card" onclick="pingBot()">
                    <div class="stat-icon">📡</div>
                    <div class="stat-info">
                        <h3 id="ping-text">Ping Bot</h3>
                        <p>Click to probe</p>
                    </div>
                </div>
            </section>

            <section class="log-section">
                <div class="section-header">
                    <h2>Recent Activities</h2>
                    <span class="badge">Live</span>
                </div>
                <div class="log-container">
                    <% logs.forEach(log => { %>
                        <div class="log-entry <%= log.type.toLowerCase() %>">
                            <span class="log-time">[<%= log.timestamp %>]</span>
                            <span class="log-type"><%= log.type %></span>
                            <span class="log-msg"><%= log.message %></span>
                        </div>
                    <% }) %>
                    <% if (logs.length === 0) { %>
                        <div class="no-logs">No activity recorded yet.</div>
                    <% } %>
                </div>
            </section>
        </main>

        <footer>
            <p>&copy; 2024 Music Bot System • Running 24/7</p>
        </footer>
    </div>

    <script>
        async function pingBot() {
            const btn = document.querySelector('.ping-card');
            const txt = document.getElementById('ping-text');
            txt.innerText = 'Pinging...';
            try {
                const start = Date.now();
                const res = await fetch('/ping');
                const data = await res.json();
                const end = Date.now();
                txt.innerText = `${end - start}ms`;
                txt.style.color = '#00ff88';
            } catch (e) {
                txt.innerText = 'Error';
                txt.style.color = '#ff4b2b';
            }
            setTimeout(() => {
                txt.innerText = 'Ping Bot';
                txt.style.color = '';
            }, 3000);
        }

        // Auto-refresh every 60 seconds to keep stats updated
        setTimeout(() => {
            location.reload();
        }, 60000);
    </script>
</body>
</html>
